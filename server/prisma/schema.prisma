generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LOW
  MID
  TOP
}

enum Provider {
  AWS
  GCP
  AZURE
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

enum PaymentProvider {
  COINBASE
  BTCPAY
  PAYMENTO
  GATEWAYCRYPTO
  NOWPAYMENTS
}

model User {
  id            String   @id
  email         String   @unique
  role          Role     @default(LOW)
  walletAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders     Order[]
  vaultCreds Credential[] @relation("SellerCreds")
}

model Product {
  id          String   @id
  name        String
  provider    Provider
  description String
  priceUsd    Float
  region      String?
  specs       Json?
  stock       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  productId       String
  status          OrderStatus     @default(PENDING)
  paymentProvider PaymentProvider?
  paymentChargeId String?
  credentialId    String?         @unique
  amountUsd       Float
  cryptoAddress   String?
  cryptoAmount    Float?
  cryptoCurrency  String?
  cryptoExpiresAt DateTime?
  cryptoNetwork   String?
  adminFee        Float?
  gatewayFee      Float?
  sellerAmount         Float?
  displayedNetworkFee  Float?
  payoutTxid           String?
  paidAt               DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  credential Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
}

model Credential {
  id        String    @id
  provider  Provider
  email     String
  password  String
  accessKey String?
  secretKey String?
  region    String?
  specs     Json?
  claimed   Boolean   @default(false)
  claimedAt DateTime?
  sellerId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orders Order[]
  seller User?  @relation("SellerCreds", fields: [sellerId], references: [id])
}

model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  event     String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("auth_events")
}
