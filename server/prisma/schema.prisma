generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Provider {
  AWS
  GCP
  AZURE
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

enum PaymentProvider {
  COINBASE
  BTCPAY
  PAYMENTO
  GATEWAYCRYPTO
  NOWPAYMENTS
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  tokenVersion Int      @default(1)
  orders       Order[]
  sessions     UserSession[]
  resetTokens  PasswordResetToken[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sid       String   @unique
  ip        String?
  subnet    String?
  userAgent String?
  city      String?
  country   String?
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@index([userId])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model AuthEvent {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  event     String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("auth_events")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  provider    Provider
  description String
  priceUsd    Float
  region      String?
  specs       Json?
  stock       Int       @default(0)
  active      Boolean   @default(true)
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Credential {
  id         String    @id @default(uuid())
  provider   Provider
  email      String
  password   String
  accessKey  String?
  secretKey  String?
  region     String?
  specs      Json?
  claimed    Boolean   @default(false)
  claimedAt  DateTime?
  order      Order?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Order {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  status          OrderStatus    @default(PENDING)
  paymentProvider PaymentProvider?
  paymentChargeId String?
  credentialId    String?        @unique
  credential      Credential?    @relation(fields: [credentialId], references: [id])
  amountUsd       Float
  paidAt          DateTime?
  deliveredAt     DateTime?
  cryptoAddress   String?
  cryptoAmount    Float?
  cryptoCurrency  String?
  cryptoNetwork   String?
  cryptoExpiresAt DateTime?
  adminFee        Float?
  gatewayFee      Float?
  sellerAmount    Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}
