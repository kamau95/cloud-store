# Firebase Admin SDK (pick ONE approach)
# Option A: Full service account JSON (recommended — paste the whole JSON file)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...",...}
# Option B: Individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n.....\n-----END PRIVATE KEY-----\n"

# Firebase Web SDK (public — sent to client via /api/auth/config)
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123

# Database
DATABASE_URL=postgresql://cloudstore:cloudstore_pass@localhost:5432/cloudstore

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true
NOWPAYMENTS_ADMIN_FEE_PERCENT=0.05
NOWPAYMENTS_CALLBACK_URL=
